# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor scratch files
*~
*.swp
*.swo

# VS Code: ignore local workspace state, allow shared tasks/debug config
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json

# Obsidian: track shared graph/config; ignore per-user workspace state
.obsidian/*
!.obsidian/graph.json
!.obsidian/app.json
!.obsidian/core-plugins.json
!.obsidian/community-plugins.json

# Local agent/tool state
.cache/
.claude/
*.codex
agent/

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# Python local environments
.python-version
.venv/
venv/
env/

# Python packaging metadata
*.egg-info/
pip-wheel-metadata/

# Build/release output
build/
dist/
*.spec

# Validation artifacts
.artifacts/
**/reports/

# Coverage output
**/coverage/
htmlcov/
.coverage
.coverage.*
coverage.xml
coverage.info
lcov.info

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.orig
